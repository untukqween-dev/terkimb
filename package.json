{
  "name": "padterm-backend",
  "version": "0.1.0",
  "description": "PadTerm Backend - Express + WebSocket",
  "private": true,
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "tsc server/index.ts --outDir dist",
    "start": "node dist/server/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.0",
    "ssh2": "^1.14.0",
    "@octokit/rest": "^20.0.0",
    "@octokit/auth-oauth-device": "^6.0.0",
    "dotenv": "^16.3.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.20",
    "@types/ws": "^8.5.8",
    "@types/ssh2": "^1.11.13",
    "@types/cors": "^2.8.15",
    "typescript": "^5.3.0",
    "tsx": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
